# NASA FIRMS API Token
# Obtenha seu token em: https://firms.modaps.eosdis.nasa.gov/api/
NTR_TOKEN=your_nasa_token_here

# Caminhos de dados
DATASET_PATH=/home/srvadmin/nokekoiApp/datasets
SUOMI_DATA_PATH=/home/srvadmin/nokekoiApp/datasets/suomi-npp-viirs-c2/South_America
PARQUET_PATH=/home/srvadmin/nokekoiApp/datasets/suomi-npp-viirs-c2/parquet
RADD_PATH=/home/srvadmin/nokekoiApp/datasets/radd
SHP_PATH=/home/srvadmin/nokekoiApp/datasets/shp

# URLs da API NASA
URL_SUOMI_VIIRS_C2=https://nrt4.modaps.eosdis.nasa.gov/api/v2/content/archives/FIRMS/suomi-npp-viirs-c2/South_America/
BASE_SUOMI_FILE_NAME=SUOMI_VIIRS_C2_South_America_VNP14IMGTDL_NRT_

# Configurações do Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Configurações de log
LOG_LEVEL=INFO
LOG_FILE=/var/log/nokekoi-app.log

# SSL/HTTPS
SSL_CERT_PATH=/etc/letsencrypt/live/nokekoi.ufac.br/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/nokekoi.ufac.br/privkey.pem

# Email para alertas (se aplicável)
ALERT_EMAIL=admin@ufac.br
SMTP_SERVER=smtp.ufac.br
SMTP_PORT=587 